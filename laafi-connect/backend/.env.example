# Supabase project (Settings > API in your Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI providers (already have keys per project notes)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional - only needed once you wire up real Android push notifications
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated list of origins allowed to call this API
ALLOWED_ORIGINS=https://your-app.vercel.app,capacitor://localhost,http://localhost:5173
